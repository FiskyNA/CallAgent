<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.CallAgent" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#1A1916</item>
        <item name="colorPrimaryVariant">#2d2b27</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#2563EB</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="android:statusBarColor">#F7F6F3</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="LabelStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#9E9C98</item>
        <item name="android:layout_marginBottom">4dp</item>
    </style>

    <style name="InputStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">#F2F1EE</item>
        <item name="android:padding">10dp</item>
        <item name="android:layout_marginBottom">14dp</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">#1A1916</item>
    </style>
</resources>
